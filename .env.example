# EML inbox folder path (absolute path recommended)
INBOX_PATH=./data/inbox

# Ollama configuration
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=mistral
EMBEDDING_MODEL=nomic-embed-text
LLM_TIMEOUT_MS=30000

# Local storage paths
DB_PATH=./data/db/mandanten.sqlite
VECTOR_STORE_PATH=./data/vector-store

# Optional: number of similar matches to retrieve
SIMILARITY_TOP_N=3
